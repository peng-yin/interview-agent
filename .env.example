# LiveKit Server
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# SiliconFlow API (用于 STT/TTS/Embedding，以及默认 LLM)
SILICONFLOW_API_KEY=your-siliconflow-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Model Configuration (optional, defaults shown)
LLM_MODEL=deepseek-ai/DeepSeek-V3
STT_MODEL=FunAudioLLM/SenseVoiceSmall
TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
TTS_VOICE=FunAudioLLM/CosyVoice2-0.5B:bella
TTS_SPEED=0.9
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ============ 可选：使用其他平台的 LLM（不设置则默认使用 SiliconFlow） ============
# --- 阿里云百炼 ---
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# LLM_MODEL=deepseek-v3
#
# --- 火山引擎（字节方舟） ---
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_API_KEY=your-volcengine-api-key
# LLM_MODEL=ep-20250xxxxx  (替换为你创建的接入点ID)
#
# --- 腾讯混元 ---
# LLM_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1
# LLM_API_KEY=your-hunyuan-api-key
# LLM_MODEL=hunyuan-pro
